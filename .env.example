# Google OAuth credentials file path
GOOGLE_CREDENTIALS_FILE=credentials.json

# Notion API
NOTION_API_KEY=secret_your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# Optional: your own email address(es), comma-separated
# Used to filter out emails sent to yourself
MY_EMAIL_ADDRESSES=you@gmail.com

# Optional: max emails to fetch per API call (default 100, max 500)
GMAIL_BATCH_SIZE=100

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
